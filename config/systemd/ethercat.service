[Unit]
Description=EtherLab EtherCAT master
After=network.target
ConditionPathExists=/etc/sysconfig/ethercat

[Service]
Type=forking
ExecStart=/opt/etherlab/etc/init.d/ethercat start
ExecStartPost=/usr/local/sbin/ecmc-ethercat-devices
ExecStop=/opt/etherlab/etc/init.d/ethercat stop
ExecReload=/opt/etherlab/etc/init.d/ethercat restart
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
